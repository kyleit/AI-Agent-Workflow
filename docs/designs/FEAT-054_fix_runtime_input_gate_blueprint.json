{
  "modules": [
    {
      "name": "workflow_runtime",
      "classes": [
        {
          "class_name": "RuntimeInputGate",
          "responsibilities": [
            "Quản lý trạng thái chờ nhập liệu, sinh token bảo mật và xác thực đầu vào."
          ],
          "methods": [
            {
              "name": "enter_waiting_state",
              "parameters": [
                {
                  "name": "prompt_id",
                  "type": "str"
                },
                {
                  "name": "question",
                  "type": "str"
                },
                {
                  "name": "options",
                  "type": "list"
                }
              ],
              "return_type": "dict"
            },
            {
              "name": "submit_input",
              "parameters": [
                {
                  "name": "prompt_id",
                  "type": "str"
                },
                {
                  "name": "value",
                  "type": "str"
                },
                {
                  "name": "source",
                  "type": "str"
                },
                {
                  "name": "token",
                  "type": "str"
                }
              ],
              "return_type": "bool"
            }
          ],
          "lifecycle": "Transient",
          "state_ownership": "Session State"
        }
      ]
    }
  ],
  "configuration": {
    "schema": {
      "pending_input": {
        "type": "object",
        "properties": {
          "input_id": {
            "type": "string"
          },
          "question": {
            "type": "string"
          },
          "options": {
            "type": "array",
            "items": {
              "type": "string"
            }
          },
          "source": {
            "type": "string"
          },
          "allow_ai_default": {
            "type": "boolean"
          },
          "allow_timeout_default": {
            "type": "boolean"
          },
          "resume_token": {
            "type": "string"
          },
          "created_at": {
            "type": "string",
            "format": "date-time"
          }
        }
      }
    },
    "defaults": {
      "pending_input": null
    }
  },
  "database": {
    "tables": [],
    "growth_estimation": "N/A",
    "maintenance_strategy": "N/A"
  },
  "cache": {
    "keys": [],
    "ttl_seconds": 0,
    "invalidation_rules": []
  },
  "errors": [
    {
      "exception_class": "ForbiddenAISourceError",
      "trigger": "Khi nhận được đầu vào submit có source=ai hoặc tương đương",
      "recovery": "Ghi nhận lỗi, tiếp tục khóa luồng ở trạng thái waiting_input"
    },
    {
      "exception_class": "InvalidResumeTokenError",
      "trigger": "Khi mã xác thực token gửi lên lệch với mã lưu trong session",
      "recovery": "Thông báo lỗi token sai, giữ nguyên trạng thái chờ"
    }
  ],
  "sequence_flows": [
    {
      "flow_name": "Normal Execution Flow",
      "steps": [
        "CLI cần nhập liệu -> enter_waiting_state()",
        "Sinh token, lưu vào .session.json, đặt status=waiting_input và dừng",
        "Người dùng submit lựa chọn kèm token qua CLI/GUI",
        "Xác thực token và nguồn -> xóa pending_input -> resume luồng thành công"
      ]
    },
    {
      "flow_name": "AI Attack Flow",
      "steps": [
        "AI Agent tự tạo lệnh submit với source=ai hoặc token giả mạo",
        "Runtime kiểm tra phát hiện nguồn bị cấm -> ném lỗi ForbiddenAISourceError -> tiếp tục dừng luồng"
      ]
    }
  ],
  "integration_contracts": [
    {
      "skill_name": "initialize-workflow",
      "description": "Khi chạy lệnh khởi tạo cần chọn quyền hạn, gọi enter_waiting_state() để ghi nhận trạng thái và dừng."
    }
  ],
  "cli_contracts": [
    {
      "command": "python skills/workflow-runtime/scripts/workflow_runtime.py input submit",
      "arguments": [
        "--input-id",
        "--value",
        "--source",
        "--resume-token"
      ]
    }
  ],
