{
  "feature_id": "FEAT-052",
  "feature_name": "Safe Implementation Orchestrator (DAG, Locks, Workers, Patches)",
  "modules": [
    {"name": "dag_planner", "classes": [{"class_name": "DAGPlanner", "responsibilities": ["Parse blueprint JSON to DAG", "Topological sort (Kahn)", "Cycle detection", "Parallel safety check"], "methods": [{"name": "build", "parameters": [{"name": "blueprint", "type": "dict"}], "return_type": "dict"}, {"name": "topological_sort", "parameters": [{"name": "graph", "type": "dict"}], "return_type": "list[str]"}, {"name": "get_execution_groups", "parameters": [{"name": "graph", "type": "dict"}], "return_type": "list[list[str]]"}, {"name": "validate", "parameters": [{"name": "blueprint", "type": "dict"}], "return_type": "list[str]"}, {"name": "check_parallel_safety", "parameters": [{"name": "tasks", "type": "list[str]"}, {"name": "blueprint", "type": "dict"}], "return_type": "bool"}], "lifecycle": "stateless", "state_ownership": "none"}]},
    {"name": "lock_manager", "classes": [{"class_name": "LockManager", "responsibilities": ["All-or-nothing file lock acquisition", "Stale lock detection via PID check", "Path security validation"], "methods": [{"name": "acquire", "parameters": [{"name": "task_id", "type": "str"}, {"name": "write_set", "type": "list[str]"}, {"name": "pid", "type": "int"}, {"name": "expires_seconds", "type": "int"}], "return_type": "bool"}, {"name": "release", "parameters": [{"name": "task_id", "type": "str"}], "return_type": "None"}, {"name": "is_stale", "parameters": [{"name": "lock_entry", "type": "dict"}], "return_type": "bool"}, {"name": "clear_stale_locks", "parameters": [], "return_type": "list[str]"}, {"name": "get_active_locks", "parameters": [], "return_type": "list[dict]"}, {"name": "has_conflict", "parameters": [{"name": "write_set", "type": "list[str]"}], "return_type": "bool"}], "lifecycle": "singleton", "state_ownership": ".agents/runtime/file-locks.json"}]},
    {"name": "worker_manager", "classes": [{"class_name": "WorkerManager", "responsibilities": ["Worker PID tracking", "Orphan detection", "Per-worker log management"], "methods": [{"name": "register", "parameters": [{"name": "task_id", "type": "str"}, {"name": "pid", "type": "int"}, {"name": "command", "type": "str"}], "return_type": "str"}, {"name": "mark_completed", "parameters": [{"name": "worker_id", "type": "str"}], "return_type": "None"}, {"name": "mark_failed", "parameters": [{"name": "worker_id", "type": "str"}, {"name": "error", "type": "str"}], "return_type": "None"}, {"name": "detect_orphans", "parameters": [], "return_type": "list[str]"}, {"name": "terminate_orphan", "parameters": [{"name": "worker_id", "type": "str"}, {"name": "force", "type": "bool"}], "return_type": "bool"}, {"name": "get_active_workers", "parameters": [], "return_type": "list[dict]"}, {"name": "has_active_workers", "parameters": [], "return_type": "bool"}], "lifecycle": "singleton", "state_ownership": ".agents/runtime/workers.json"}]},
    {"name": "orchestrator", "classes": [{"class_name": "SafeOrchestrator", "responsibilities": ["DAG execution controller", "Lock+worker coordination", "Completion gate enforcement", "Abort and resume support"], "methods": [{"name": "run_phase", "parameters": [{"name": "phase_id", "type": "str"}, {"name": "blueprint", "type": "dict"}, {"name": "mode", "type": "str"}], "return_type": "dict"}, {"name": "run_task", "parameters": [{"name": "task", "type": "dict"}, {"name": "blueprint", "type": "dict"}], "return_type": "dict"}, {"name": "check_completion_gate", "parameters": [], "return_type": "tuple[bool, list[str]]"}, {"name": "abort", "parameters": [{"name": "ask_before_kill", "type": "bool"}], "return_type": "None"}, {"name": "resume", "parameters": [], "return_type": "str | None"}], "lifecycle": "singleton per execution", "state_ownership": "coordinates ledger, locks, workers"}]},
    {"name": "patch_applier", "classes": [{"class_name": "PatchApplier", "responsibilities": ["Validate patch scope vs write_set", "Apply patch with dry-run first", "Rollback patch"], "methods": [{"name": "apply", "parameters": [{"name": "task_id", "type": "str"}, {"name": "patch_path", "type": "str"}, {"name": "write_set", "type": "list[str]"}], "return_type": "dict"}, {"name": "validate_patch_scope", "parameters": [{"name": "patch_path", "type": "str"}, {"name": "write_set", "type": "list[str]"}], "return_type": "list[str]"}, {"name": "rollback_patch", "parameters": [{"name": "patch_path", "type": "str"}], "return_type": "bool"}], "lifecycle": "stateless", "state_ownership": "none"}]}
  ],
  "configuration": {
    "schema": {"orchestrator": {"default_mode": "string", "allow_controlled_parallel": "boolean", "lock_expiry_seconds": "integer", "orphan_check_on_complete": "boolean", "patch_mode": "boolean"}},
    "defaults": {"orchestrator.default_mode": "safe_sequential", "orchestrator.allow_controlled_parallel": false, "orchestrator.lock_expiry_seconds": 300, "orchestrator.orphan_check_on_complete": true, "orchestrator.patch_mode": false}
  },
  "database": {
    "tables": [],
    "growth_estimation": "file-locks.json and workers.json ~1-5KB each; cleaned after each task completion",
    "maintenance_strategy": "Locks released after task; workers cleaned after phase; stale entries cleared at task start"
  },
  "cache": {"keys": [], "ttl_seconds": 0, "invalidation_rules": ["No cache; lock/worker state always read from disk to prevent race conditions"]},
  "errors": [
    {"exception_class": "CyclicDependencyError", "trigger": "Cycle detected in task DAG", "recovery": "Stop implementation; print cycle path"},
    {"exception_class": "FileLockConflict", "trigger": "Lock acquisition fails (file already locked)", "recovery": "Return False; task queued to retry"},
    {"exception_class": "OrphanWorkerError", "trigger": "Worker alive after task claimed complete", "recovery": "Block phase completion; prompt implement abort"},
    {"exception_class": "PatchConflictError", "trigger": "Patch touches files outside write_set", "recovery": "Stop task; do not apply patch"},
    {"exception_class": "CompletionGateError", "trigger": "Completion gate fails", "recovery": "Block checkpoint advance; print all failing reasons"}
  ],
  "sequence_flows": [
    {
      "flow_name": "Safe Sequential Task Execution",
      "steps": [
        "orchestrator.run_task(task, blueprint) called",
        "dag_planner.validate() confirms write_set paths relative and in workspace",
        "lock_manager.acquire(task_id, write_set, pid) → all-or-nothing",
        "If any lock held: task queued; retry after dependency completes",
        "Task executed; worker PID registered via worker_manager.register()",
        "patch_applier.apply() if patch mode enabled",
        "Verify expected output files exist",
        "lock_manager.release(task_id)",
        "worker_manager.mark_completed(worker_id)",
        "ledger.mark_task_completed(task_id)"
      ]
    },
    {
      "flow_name": "Completion Gate Check",
      "steps": [
        "orchestrator.check_completion_gate() called after all tasks",
        "Check 1: All tasks completed in ledger",
        "Check 2: No running/queued/blocked/failed tasks",
        "Check 3: worker_manager.has_active_workers() → False required",
        "Check 4: lock_manager.get_active_locks() → empty required",
        "Check 5: Expected output files exist on disk",
        "If any check fails → return (False, [failing_reasons])",
        "Phase NOT marked complete; gate failures printed"
      ]
    }
  ],
  "integration_contracts": [
    {"skill": "blueprint-to-implementation", "safe_execution_policy": "Must add policy section; parallel definitions are candidates only; default safe_sequential"}
  ],
  "cli_contracts": [
    {"command": "implement abort", "output": "JSON {workers_killed, locks_released}", "exit_codes": {"0": "success"}},
    {"command": "implement resume", "output": "JSON {task_id, phase_id, ready_to_run}", "exit_codes": {"0": "resumed", "1": "nothing"}},
    {"command": "implement status", "output": "JSON {tasks[], locks[], workers[], gate_status}", "exit_codes": {"0": "success"}}
  ],
  "implementation_contracts": [
    {"file_path": "skills/workflow-runtime/scripts/dag_planner.py", "owner": "Coder", "notes": "Pure algorithm; GLOBAL_FILES list hard-coded; Kahn's algorithm for topological sort"},
    {"file_path": "skills/workflow-runtime/scripts/lock_manager.py", "owner": "Coder", "notes": "os.kill(pid, 0) for PID check; catch both OSError and ProcessLookupError; all-or-nothing atomic acquisition"},
    {"file_path": "skills/workflow-runtime/scripts/worker_manager.py", "owner": "Coder", "notes": "Log dir: .agents/runtime/logs/; create on first use"},
    {"file_path": "skills/workflow-runtime/scripts/orchestrator.py", "owner": "Coder", "notes": "Default mode MUST be safe_sequential; completion gate non-negotiable"},
    {"file_path": "skills/workflow-runtime/scripts/patch_applier.py", "owner": "Coder", "notes": "git apply --check for dry-run; fallback to manual parsing if git unavailable; never apply without scope validation"}
  ],
  "implementation_packages": [
    {"task_id": "Task 1.1", "module": "dag_planner", "read_set": [], "write_set": ["skills/workflow-runtime/scripts/dag_planner.py"], "dependencies": [], "implementation_notes": "Pure algorithm; no file I/O except reading blueprint dict", "verification": "python -m pytest skills/workflow-runtime/tests/test_dag_planner.py", "rollback": "Delete dag_planner.py", "expected_outputs": ["dag_planner.py created", "tests pass"]},
    {"task_id": "Task 1.2", "module": "lock_manager", "read_set": [".agents/runtime/file-locks.json"], "write_set": ["skills/workflow-runtime/scripts/lock_manager.py", ".agents/runtime/file-locks.json"], "dependencies": [], "implementation_notes": "All-or-nothing: read locks → check conflicts → acquire all or acquire none", "verification": "python -m pytest skills/workflow-runtime/tests/test_file_locks.py", "rollback": "Delete lock_manager.py; rm .agents/runtime/file-locks.json", "expected_outputs": ["lock_manager.py created", "tests pass"]},
    {"task_id": "Task 1.3", "module": "worker_manager", "read_set": [".agents/runtime/workers.json"], "write_set": ["skills/workflow-runtime/scripts/worker_manager.py", ".agents/runtime/workers.json"], "dependencies": [], "implementation_notes": "Log dir auto-created; PID liveness check cross-platform", "verification": "python -m pytest skills/workflow-runtime/tests/test_worker_registry.py", "rollback": "Delete worker_manager.py; rm .agents/runtime/workers.json", "expected_outputs": ["worker_manager.py created", "tests pass"]},
    {"task_id": "Task 2.1", "module": "orchestrator", "read_set": ["skills/workflow-runtime/scripts/dag_planner.py", "skills/workflow-runtime/scripts/lock_manager.py", "skills/workflow-runtime/scripts/worker_manager.py"], "write_set": ["skills/workflow-runtime/scripts/orchestrator.py"], "dependencies": ["Task 1.1", "Task 1.2", "Task 1.3"], "implementation_notes": "Completion gate has 9 conditions; all checked independently", "verification": "python -m pytest skills/workflow-runtime/tests/test_task_dag_execution.py", "rollback": "Delete orchestrator.py", "expected_outputs": ["orchestrator.py created", "tests pass"]},
    {"task_id": "Task 2.2", "module": "patch_applier", "read_set": ["skills/workflow-runtime/scripts/lock_manager.py"], "write_set": ["skills/workflow-runtime/scripts/patch_applier.py"], "dependencies": ["Task 2.1"], "implementation_notes": "git apply --check before actual apply; workspace files modified only after scope validation", "verification": "python -m pytest skills/workflow-runtime/tests/test_task_dag_execution.py -k patch", "rollback": "Delete patch_applier.py", "expected_outputs": ["patch_applier.py created", "tests pass"]}
  ],
  "tests": [
