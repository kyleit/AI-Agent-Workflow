  "configuration": {
    "schema": {
      "pricing_json": {
        "version": "semver string",
        "updated_at": "YYYY-MM-DD",
        "providers": {
          "<provider_id>": {
            "models": {
              "<model_id>": {
                "input_per_mtok": "float >= 0",
                "output_per_mtok": "float >= 0",
                "cache_read_per_mtok": "float >= 0",
                "cache_write_per_mtok": "float >= 0",
                "thinking_per_mtok": "float >= 0 (optional)"
              }
            }
          }
        },
        "fallback": {
          "input_per_mtok": "float",
          "output_per_mtok": "float"
        }
      },
      "connectors_json": {
        "connectors": [
          {
            "name": "string — canonical provider name",
            "module": "string — Python module path",
            "class": "string — class name in module",
            "enabled": "boolean"
          }
        ]
      }
    },
    "defaults": {
      "pricing_stale_days": 30,
      "transcript_cursor_ttl_days": 90,
      "diagnostics_refresh_interval_ms": 300000
    }
  },
  "database": {
    "tables": [
      {
        "name": "transcript_cursors",
        "operation": "CREATE",
        "columns": ["file_path TEXT PRIMARY KEY", "byte_pos INTEGER NOT NULL DEFAULT 0", "file_hash TEXT NOT NULL DEFAULT ''", "updated_at TEXT NOT NULL"],
        "indexes": []
      },
      {
        "name": "runtime_events",
        "operation": "CREATE",
        "columns": ["id INTEGER PRIMARY KEY AUTOINCREMENT", "event_id TEXT NOT NULL UNIQUE", "timestamp TEXT NOT NULL", "conversation_id TEXT NOT NULL", "provider TEXT NOT NULL", "event_type TEXT NOT NULL", "event_data_json TEXT NOT NULL"],
        "indexes": ["idx_runtime_events_conv ON runtime_events(conversation_id)", "idx_runtime_events_type ON runtime_events(event_type)"]
      },
      {
        "name": "connector_diagnostics",
        "operation": "CREATE",
        "columns": ["id INTEGER PRIMARY KEY AUTOINCREMENT", "timestamp TEXT NOT NULL", "provider TEXT NOT NULL", "status TEXT NOT NULL", "detected_path TEXT", "error_message TEXT", "accuracy_confidence TEXT NOT NULL"],
        "indexes": ["idx_connector_diag_provider ON connector_diagnostics(provider)"]
      },
      {
        "name": "provider_requests",
        "operation": "ALTER ADD COLUMN",
        "new_columns": ["accuracy_source TEXT DEFAULT 'estimated'", "raw_payload TEXT"],
        "indexes": []
      }
    ],
    "growth_estimation": "runtime_events: ~50 rows/session, ~1500 rows/month. connector_diagnostics: ~4 rows/refresh, prunable. transcript_cursors: 1 row per unique transcript file. provider_requests: existing growth rate unchanged.",
    "maintenance_strategy": "transcript_cursors: delete rows where updated_at older than 90 days on init. connector_diagnostics: keep last 100 rows per provider. runtime_events: archive or delete conversations older than 30 days."
  },
  "cache": {
    "keys": ["transcript_cursors.file_path (absolute path as primary key)", "CostEngine in-memory pricing dict keyed by provider+model"],
    "ttl_seconds": -1,
    "invalidation_rules": [
      "transcript_cursors: invalidated when MD5(file_path + byte_pos + mtime_ns) changes",
      "CostEngine pricing: invalidated only on process restart or explicit reload()",
      "DiagnosticsPanel: refreshed every 300s (5 minutes) regardless of cache"
    ]
  },
  "errors": [
    { "exception_class": "ConnectorNotFoundError", "trigger": "registry.parse() called with unregistered provider_name", "recovery": "log to connector_diagnostics, return []" },
    { "exception_class": "TranscriptNotFoundError", "trigger": "read_new_lines() on non-existent path", "recovery": "log to connector_diagnostics with status=NOT_FOUND, return []" },
    { "exception_class": "PricingModelNotFoundError", "trigger": "calculate() called with unknown provider/model", "recovery": "use fallback pricing block, set fallback_used=True" },
    { "exception_class": "TranscriptParseError", "trigger": "malformed JSON line in .jsonl file", "recovery": "skip line, log WARNING with raw_content[:100]" },
    { "exception_class": "FileLockedError", "trigger": "PermissionError on Windows when IDE holds file lock", "recovery": "retry 3x at 100ms/200ms/400ms, then log WARNING and return []" }
  ],
  "sequence_flows": [
    {
      "flow_name": "Extension Dashboard Refresh",
      "steps": [
        "Extension updateSessionData() triggered by file watcher",
        "spawn('provider_engine.py parse --provider antigravity --conv-id {conv_id}')",
        "ConnectorRegistry.parse('antigravity', conv_id)",
        "AntigravityConnector.parse_conversation(conv_id)",
        "IncrementalTranscriptReader.read_new_lines(transcript_path) — cache check",
        "TranscriptParser parses each new line → raw dicts",
        "UsageNormalizer.normalize() → NormalizedUsageRecord[]",
        "CostEngine.calculate() for each record",
        "Records written to SQLite provider_requests with accuracy_source",
        "JSON output to stdout",
        "Extension updates all metric cards with AccuracyBadge"
      ]
    },
    {
      "flow_name": "DiagnosticsPanel Refresh",
      "steps": [
        "Extension calls spawn('provider_engine.py diagnose')",
        "ConnectorRegistry.diagnose_all() → per-connector get_diagnostics()",
        "Each connector checks path, permissions, last parsed timestamp",
        "Results written to connector_diagnostics SQLite table",
        "JSON DiagnosticsReport returned to Extension",
        "DiagnosticsPanel updated: green/amber/red per provider"
      ]
    },
    {
      "flow_name": "Cache Miss Full Parse (First Run)",
      "steps": [
        "IncrementalTranscriptReader.read_new_lines(file_path)",
        "No entry in transcript_cursors → byte_pos = 0",
        "Open file, stream read all lines in 1MB buffer chunks",
        "Parse each JSONL line, skip malformed (log WARNING)",
        "Save final byte_pos and file_hash to transcript_cursors",
        "Return all parsed records (target: <5s for 50MB)"
      ]
    }
  ],
  "integration_contracts": [
    {
      "skill": "initialize-workflow",
      "before_hooks": "none",
      "after_hooks": "sync_request_history() unchanged",
      "data_exchanged": "context_usage dict interface unchanged"
    },
    {
      "skill": "workflow-runtime",
      "before_hooks": "provider_engine.py detect called by Extension on activation",
      "after_hooks": "provider_engine.py parse called after each session update",
      "data_exchanged": "NormalizedUsageRecord[] JSON via stdout"
    }
  ],
  "cli_contracts": [
    { "command": "python provider_engine.py detect", "output_schema": "DetectedProvider[]", "exit_codes": [0, 1] },
    { "command": "python provider_engine.py parse --provider <name> --conv-id <id>", "output_schema": "NormalizedUsageRecord[]", "exit_codes": [0, 1, 2] },
    { "command": "python provider_engine.py pricing --provider <n> --model <m> --input <i> --output <o>", "output_schema": "CostResult", "exit_codes": [0] },
    { "command": "python provider_engine.py diagnose", "output_schema": "DiagnosticsReport", "exit_codes": [0] },
    { "command": "python workflow_runtime.py provider <subcommand> [args]", "output_schema": "passthrough from provider_engine.py", "exit_codes": [0, 1, 2] }
  ],
