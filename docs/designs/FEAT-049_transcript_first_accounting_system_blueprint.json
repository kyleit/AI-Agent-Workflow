{
  "feature_id": "FEAT-049",
  "feature_name": "Transcript-First Accounting System",
  "modules": [
    {
      "name": "fingerprint_engine",
      "file": "skills/workflow-runtime/scripts/fingerprint_engine.py",
      "operation": "NEW",
      "classes": [
        {
          "class_name": "FingerprintEngineError",
          "responsibilities": ["Custom exception for fingerprint computation and DB failures"],
          "methods": [],
          "lifecycle": "exception",
          "state_ownership": "none"
        },
        {
          "class_name": "FingerprintEngine",
          "responsibilities": [
            "Compute SHA-256 fingerprint from canonical field ordering",
            "Check request_fingerprints table for duplicates",
            "Register new fingerprints; increment duplicate_count on collision"
          ],
          "methods": [
            {"name": "compute", "parameters": [{"name": "fields", "type": "dict"}], "return_type": "str"},
            {"name": "is_duplicate", "parameters": [{"name": "fingerprint", "type": "str"}], "return_type": "bool"},
            {"name": "register", "parameters": [{"name": "fingerprint", "type": "str"}, {"name": "metadata", "type": "dict"}], "return_type": "bool"},
            {"name": "get_stats", "parameters": [], "return_type": "dict"},
            {"name": "_canonical_string", "parameters": [{"name": "fields", "type": "dict"}], "return_type": "str"},
            {"name": "_compute_payload_hash", "parameters": [{"name": "raw_payload", "type": "dict"}], "return_type": "str"}
          ],
          "lifecycle": "instantiated per parse cycle with db_conn",
          "state_ownership": "SQLite request_fingerprints table"
        }
      ]
    },
    {
      "name": "reconciliation_engine",
      "file": "skills/workflow-runtime/scripts/reconciliation_engine.py",
      "operation": "NEW",
      "classes": [
        {
          "class_name": "ReconciliationReport",
          "responsibilities": ["Dataclass: 8-field stats + confidence_score + duration_ms"],
          "methods": [{"name": "to_dict", "parameters": [], "return_type": "dict"}],
          "lifecycle": "dataclass; created by ReconciliationEngine.sync()",
          "state_ownership": "none (immutable)"
        },
        {
          "class_name": "ReconciliationEngine",
          "responsibilities": [
            "Aggregate fingerprint stats across all provider transcripts",
            "Produce deterministic idempotent ReconciliationReport",
            "Persist report to reconciliation_reports table"
          ],
          "methods": [
            {"name": "sync", "parameters": [{"name": "transcript_paths", "type": "Optional[List[str]]", "default": "None"}], "return_type": "ReconciliationReport"},
            {"name": "get_last_report", "parameters": [], "return_type": "Optional[ReconciliationReport]"},
            {"name": "get_report_by_id", "parameters": [{"name": "report_id", "type": "int"}], "return_type": "Optional[ReconciliationReport]"},
            {"name": "_process_transcript", "parameters": [{"name": "file_path", "type": "str"}], "return_type": "dict"},
            {"name": "_compute_confidence", "parameters": [{"name": "stats", "type": "dict"}], "return_type": "float"},
            {"name": "_persist_report", "parameters": [{"name": "report", "type": "ReconciliationReport"}], "return_type": "int"}
          ],
          "lifecycle": "instantiated per sync cycle",
          "state_ownership": "SQLite reconciliation_reports table"
        }
      ]
    },
    {
      "name": "usage_validator",
      "file": "skills/workflow-runtime/scripts/usage_validator.py",
      "operation": "NEW",
      "classes": [
        {
          "class_name": "ValidationResult",
          "responsibilities": ["Dataclass: violations list"],
          "methods": [{"name": "to_dict", "parameters": [], "return_type": "dict"}],
          "lifecycle": "dataclass", "state_ownership": "none"
        },
        {
          "class_name": "DoctorReport",
          "responsibilities": ["Dataclass: violations + suggestions + confidence_score"],
          "methods": [{"name": "to_dict", "parameters": [], "return_type": "dict"}],
          "lifecycle": "dataclass", "state_ownership": "none"
        },
        {
          "class_name": "DiffReport",
          "responsibilities": ["Dataclass: delta between two ReconciliationReport rows"],
          "methods": [{"name": "to_dict", "parameters": [], "return_type": "dict"}],
          "lifecycle": "dataclass", "state_ownership": "none"
        },
        {
          "class_name": "UsageValidator",
          "responsibilities": [
            "CLI entry point for validate / reconcile / doctor / diff",
            "Detect impossible values in provider_requests",
            "Delegate reconcile to ReconciliationEngine"
          ],
          "methods": [
            {"name": "validate", "parameters": [{"name": "conn", "type": "sqlite3.Connection"}], "return_type": "ValidationResult"},
            {"name": "reconcile", "parameters": [{"name": "conn", "type": "sqlite3.Connection"}], "return_type": "ReconciliationReport"},
            {"name": "doctor", "parameters": [{"name": "conn", "type": "sqlite3.Connection"}], "return_type": "DoctorReport"},
            {"name": "diff", "parameters": [{"name": "conn", "type": "sqlite3.Connection"}, {"name": "run_id_a", "type": "int"}, {"name": "run_id_b", "type": "int"}], "return_type": "DiffReport"}
          ],
          "lifecycle": "instantiated per CLI invocation",
          "state_ownership": "none (read-only except reconcile)"
        }
      ]
    },
    {
      "name": "connectors/base extensions",
      "file": "skills/workflow-runtime/scripts/connectors/base.py",
      "operation": "MODIFY",
      "classes": [
        {
          "class_name": "ITranscriptParser",
          "responsibilities": [
            "Abstract interface for provider-specific transcript parsing with fingerprint",
            "Does NOT inherit ProviderConnector (separate interface; composed not inherited)"
          ],
          "methods": [
            {"name": "compute_fingerprint", "parameters": [{"name": "raw_line", "type": "dict"}], "return_type": "str"},
            {"name": "extract_tool_tokens", "parameters": [{"name": "raw_line", "type": "dict"}], "return_type": "int"},
            {"name": "get_usage_source", "parameters": [{"name": "raw_line", "type": "dict"}], "return_type": "str"},
            {"name": "parse_with_fingerprint", "parameters": [{"name": "raw_line", "type": "dict"}, {"name": "offset", "type": "int"}, {"name": "fp_engine", "type": "FingerprintEngine"}], "return_type": "Optional[NormalizedUsageRecord]"}
          ],
          "lifecycle": "abstract", "state_ownership": "none"
        },
        {
          "class_name": "NormalizedUsageRecord v2",
          "responsibilities": [
            "Extended with 4 new optional fields",
            "fingerprint: Optional[str]=None",
            "tool_tokens: int=0 (NOT in total_tokens)",
            "transcript_offset: int=-1",
            "raw_metadata: Optional[dict]=None"
          ],
          "methods": [
            {"name": "__post_init__", "parameters": [], "return_type": "None"},
            {"name": "to_dict", "parameters": [], "return_type": "dict"}
          ],
          "lifecycle": "dataclass", "state_ownership": "none"
        }
      ]
    },
    {
      "name": "cost_engine v2",
      "file": "skills/workflow-runtime/scripts/cost_engine.py",
      "operation": "MODIFY",
      "classes": [
        {
          "class_name": "CostEngine v2",
          "responsibilities": [
            "Versioned pricing lookup by effective_date",
            "Historical cost lock (immutable once set)",
            "tool_cost from tool_per_mtok"
          ],
          "methods": [
            {"name": "__init__", "parameters": [{"name": "pricing_path", "type": "Optional[str]", "default": "None"}, {"name": "db_conn", "type": "Optional[sqlite3.Connection]", "default": "None"}], "return_type": "None"},
            {"name": "calculate", "parameters": [{"name": "record", "type": "NormalizedUsageRecord"}, {"name": "request_timestamp", "type": "Optional[str]", "default": "None"}, {"name": "pricing_version", "type": "Optional[str]", "default": "None"}], "return_type": "CostResult"},
            {"name": "get_pricing_version", "parameters": [{"name": "provider", "type": "str"}, {"name": "model", "type": "str"}, {"name": "timestamp", "type": "str"}], "return_type": "Optional[str]"},
            {"name": "lock_cost", "parameters": [{"name": "conn", "type": "sqlite3.Connection"}, {"name": "request_id", "type": "str"}, {"name": "cost_result", "type": "CostResult"}, {"name": "pricing_version", "type": "str"}], "return_type": "None"}
          ],
          "lifecycle": "singleton per session",
          "state_ownership": "in-memory pricing cache + SQLite pricing_versions"
        }
      ]
    }
  ],
  "configuration": {
    "schema": {
      "pricing_json_schema_version": "2.0",
      "fields_per_model": ["version", "effective_date", "input_per_mtok", "output_per_mtok", "cache_read_per_mtok", "cache_write_per_mtok", "thinking_per_mtok", "tool_per_mtok"]
    },
    "defaults": {
      "tool_per_mtok": 0.0,
      "default_version": "1.0.0",
      "bootstrap_effective_date": "2026-01-01"
    }
  },
  "database": {
    "tables": [
      {
        "name": "request_fingerprints",
        "operation": "NEW",
        "columns": ["fingerprint TEXT PK", "provider TEXT NOT NULL", "conv_id TEXT NOT NULL", "request_id TEXT NOT NULL", "model TEXT NOT NULL", "timestamp TEXT NOT NULL", "duplicate_count INTEGER DEFAULT 0", "first_seen TEXT NOT NULL", "last_seen TEXT NOT NULL"],
        "indexes": ["idx_fingerprints_hash UNIQUE ON fingerprint", "idx_fingerprints_conv ON conv_id"]
      },
      {
        "name": "pricing_versions",
        "operation": "NEW",
        "columns": ["id INTEGER PK AUTOINCREMENT", "provider TEXT NOT NULL", "model TEXT NOT NULL", "version TEXT NOT NULL", "effective_date TEXT NOT NULL", "input_per_mtok REAL DEFAULT 0.0", "output_per_mtok REAL DEFAULT 0.0", "cache_read_per_mtok REAL DEFAULT 0.0", "cache_write_per_mtok REAL DEFAULT 0.0", "thinking_per_mtok REAL DEFAULT 0.0", "tool_per_mtok REAL DEFAULT 0.0", "created_at TEXT NOT NULL", "UNIQUE(provider, model, version)"],
        "indexes": ["idx_pricing_versions_effective ON (provider, model, effective_date DESC)"]
      },
      {
        "name": "reconciliation_reports",
        "operation": "NEW",
        "columns": ["id INTEGER PK AUTOINCREMENT", "timestamp TEXT NOT NULL", "requests_discovered INTEGER DEFAULT 0", "requests_parsed INTEGER DEFAULT 0", "duplicates_ignored INTEGER DEFAULT 0", "corrupted_transcripts INTEGER DEFAULT 0", "missing_usage_metadata INTEGER DEFAULT 0", "reconstructed_usage INTEGER DEFAULT 0", "estimated_usage INTEGER DEFAULT 0", "confidence_score REAL DEFAULT 0.0", "duration_ms INTEGER DEFAULT 0"],
        "indexes": ["idx_reconciliation_timestamp ON timestamp DESC"]
      },
      {
        "name": "provider_requests (additive columns)",
        "operation": "MODIFY",
        "new_columns": ["fingerprint TEXT DEFAULT NULL", "pricing_version TEXT DEFAULT ''", "tool_tokens INTEGER DEFAULT 0", "transcript_offset INTEGER DEFAULT -1"],
        "migration": "try/except OperationalError (idempotent ALTER TABLE ADD COLUMN)"
      }
    ],
    "growth_estimation": "request_fingerprints: ~1 row/request. pricing_versions: few rows/model update. reconciliation_reports: ~1 row/sync cycle. Estimate: <50k rows/table for typical usage.",
    "maintenance_strategy": "No automatic pruning in FEAT-049. Future: cleanup oldest N reconciliation_reports. request_fingerprints and pricing_versions are permanent audit records."
  },
  "cache": {
    "keys": ["(provider, model, version) -> ModelPricing in CostEngine._data"],
    "ttl_seconds": -1,
    "invalidation_rules": ["CostEngine.is_stale() detects pricing.json mtime change"]
  },
  "errors": [
    {"exception_class": "FingerprintEngineError", "trigger": "hashlib unavailable; SQLite write failure; malformed fingerprint", "recovery": "Return None fingerprint; set accuracy_source=estimated; log ERROR"},
    {"exception_class": "ReconciliationError", "trigger": "DB write failure during persist; registry unavailable", "recovery": "Return partial report with confidence_score=0.0; log ERROR"},
    {"exception_class": "PricingVersionNotFoundError", "trigger": "No pricing_versions row matches (provider, model, timestamp)", "recovery": "Fallback to current pricing.json; CostResult.fallback_used=True; log WARNING"},
    {"exception_class": "TranscriptCorruptionWarning (non-raising)", "trigger": "JSON parse fails on transcript line", "recovery": "Skip line; increment corrupted_transcripts; log WARNING with offset"},
    {"exception_class": "ImpossibleValueWarning (non-raising)", "trigger": "Negative tokens; total < input+output; empty model; future timestamp", "recovery": "Flag in DoctorReport only; do not skip or correct record"}
  ],
  "sequence_flows": [
    {
      "flow_name": "Normal Parse Flow (Phase 1+2 integrated)",
      "steps": ["provider_engine.py parse invoked", "ConnectorRegistry detects active providers", "connector.parse_with_fingerprint(raw_line, offset, fp_engine)", "FingerprintEngine.compute(fields) => fingerprint", "FingerprintEngine.is_duplicate(fp) => False", "FingerprintEngine.register(fp, metadata) => True", "NormalizedUsageRecord v2 built", "CostEngine v2.calculate(record, timestamp) => CostResult (versioned)", "CostEngine.lock_cost(conn, request_id, cost_result, pricing_version)", "batch_insert_provider_requests(conn, [record])", "ReconciliationEngine.sync() => ReconciliationReport", "Output: usage JSON + reconciliation_summary"]
    },
    {
      "flow_name": "Duplicate Detection Flow",
      "steps": ["FingerprintEngine.compute(fields) => fingerprint F", "FingerprintEngine.is_duplicate(F) => True", "FingerprintEngine.register(F, metadata) => False (duplicate_count += 1)", "parse_with_fingerprint() returns None", "ReconciliationEngine: duplicates_ignored += 1"]
    },
    {
      "flow_name": "Incremental Rescan (no new data)",
      "steps": ["IncrementalTranscriptReader.read_new_lines() called", "file_hash unchanged => return []", "ReconciliationEngine.sync() => report with requests_discovered=0", "New row inserted in reconciliation_reports (idempotent)"]
    },
    {
      "flow_name": "Historical Cost Lock (usage reprice)",
      "steps": ["usage reprice called explicitly by user", "CostEngine loads latest pricing.json", "For each provider_requests WHERE pricing_version IS NULL or empty: compute new cost", "UPDATE provider_requests SET cost_usd=new_cost, pricing_version='reprice-YYYY-MM-DD'", "INSERT new pricing_versions snapshot row"]
    }
  ],
  "integration_contracts": [
    {
      "skill": "workflow-runtime",
      "before_hooks": ["fingerprint_engine.py importable before provider parse cycle"],
      "after_hooks": ["ReconciliationEngine.sync() called after every parse cycle"],
      "runtime_calls": ["usage_validator.py reconcile on 5-min timer from extension.ts"],
      "data_exchanged": ["provider_engine.py outputs reconciliation_summary alongside usage JSON"]
    }
  ],
  "cli_contracts": [
    {"command": "python usage_validator.py validate [--db PATH]", "output": "JSON: {status, violations, count}", "exit_codes": {"0": "clean", "1": "violations", "2": "fatal"}},
    {"command": "python usage_validator.py reconcile [--db PATH]", "output": "JSON: ReconciliationReport", "exit_codes": {"0": "ok", "2": "fatal"}},
    {"command": "python usage_validator.py doctor [--db PATH]", "output": "JSON: {violations, suggestions, confidence_score}", "exit_codes": {"0": "always (diagnostic)"}},
    {"command": "python usage_validator.py diff --run-a INT --run-b INT [--db PATH]", "output": "JSON: {delta, run_a, run_b}", "exit_codes": {"0": "ok", "2": "run_id not found"}}
  ],
  "implementation_contracts": [
    {"file_path": "skills/workflow-runtime/scripts/fingerprint_engine.py", "owner": "Coder", "notes": "compute() must be pure (no DB). register() is sole DB writer. Never raise from compute()."},
    {"file_path": "skills/workflow-runtime/scripts/reconciliation_engine.py", "owner": "Coder", "notes": "sync() idempotent. Each call inserts new row (no update). confidence = parsed / max(1, parsed+corrupted+missing)."},
    {"file_path": "skills/workflow-runtime/scripts/usage_validator.py", "owner": "Coder", "notes": "doctor() must never crash. diff() with missing run IDs: exit 2."},
    {"file_path": "skills/workflow-runtime/scripts/connectors/base.py", "owner": "Coder", "notes": "ITranscriptParser does NOT inherit ProviderConnector. tool_tokens NOT added to total_tokens. Extend accuracy_source valid set."},
    {"file_path": "skills/workflow-runtime/scripts/transcript_engine.py", "owner": "Coder", "notes": "Open in rb mode. offset = f.tell() before readline(). Decode UTF-8 errors=replace. Update all callers."},
    {"file_path": "skills/workflow-runtime/scripts/cost_engine.py", "owner": "Coder", "notes": "db_conn optional (None = backward compat). lock_cost WHERE guard: pricing_version IS NULL OR pricing_version = ''."},
    {"file_path": "extensions/visualizer/resources/webview.html", "owner": "Coder", "notes": "Run node build.js after every edit to sync webviewHtml.ts."}
  ],
