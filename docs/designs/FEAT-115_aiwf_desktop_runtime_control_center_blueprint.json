{
  "modules": [
    {
      "name": "Registry",
      "classes": [
        {
          "class_name": "Registry",
          "responsibilities": [
            "Maintain list of active user project paths",
            "Serialize config to projects.json"
          ],
          "methods": [
            {
              "name": "RegisterProject",
              "parameters": [
                "path"
              ],
              "return_type": "Project"
            },
            {
              "name": "GetProjects",
              "parameters": [],
              "return_type": "[]Project"
            },
            {
              "name": "DeleteProject",
              "parameters": [
                "id"
              ],
              "return_type": "error"
            }
          ],
          "lifecycle": "Singleton persisted on local config directory",
          "state_ownership": "Local OS config file path"
        }
      ]
    },
    {
      "name": "Supervisor",
      "classes": [
        {
          "class_name": "Supervisor",
          "responsibilities": [
            "Manage WebSocket connection pools to local python runtimes",
            "Dispatch reactive events to Wails Svelte components"
          ],
          "methods": [
            {
              "name": "ConnectProject",
              "parameters": [
                "id",
                "port"
              ],
              "return_type": "error"
            },
            {
              "name": "DisconnectProject",
              "parameters": [
                "id"
              ],
              "return_type": "error"
            }
          ],
          "lifecycle": "Active during application runtime",
          "state_ownership": "In-memory maps in Go"
        }
      ]
    }
  ],
  "configuration": {
    "schema": {
      "projects": [
        {
          "id": "string (uuid)",
          "name": "string",
          "path": "string",
          "port": "integer"
        }
      ]
    },
    "defaults": {
      "projects": []
    }
  },
  "database": {
    "tables": [
      "provider_requests",
      "workflow_runs"
    ],
    "growth_estimation": "Minimal. Client runs in read-only mode over SQLite databases",
    "maintenance_strategy": "Database connection handles are released instantly after queries"
  },
  "cache": {
    "keys": [
      "projects_list_cache"
    ],
    "ttl_seconds": 0,
    "invalidation_rules": [
      "Configuration mutated (RegisterProject, DeleteProject)"
    ]
  },
  "errors": [
    {
      "exception_class": "ConnectionError",
      "trigger": "Local WebSocket connection to python port drops unexpectedly",
      "recovery": "Activate connection retry loop every 1.5 seconds up to 10 attempts"
    },
    {
      "exception_class": "ErrOrchestratorLocked",
      "trigger": "Subprocess start request triggers when SQLite locks or lock lease is active",
      "recovery": "Display notification error banner to user and abort launch"
    }
  ],
  "sequence_flows": [
    {
      "flow_name": "Start Orchestrator Sequence Flow",
      "steps": [
        "Svelte UI triggers Wails bind executor StartOrchestrator(path)",
        "Lock checker queries SQLite lease active status & lock files",
        "If unlocked, executor spawns python runtime CLI command subprocess",
        "Supervisor starts WebSocket connection handler to telemetry port",
        "Svelte UI receives event updates and changes node status indicators"
      ]
    }
  ],
