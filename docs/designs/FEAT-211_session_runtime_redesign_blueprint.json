{
  "modules": [
    {
      "name": "session_core",
      "classes": [
        {
          "class_name": "SessionRuntimeCore",
          "responsibilities": ["Quản lý vòng đời phiên làm việc, trạng thái state machine và phân quyền phiên"],
          "methods": [
            {
              "name": "create_session",
              "parameters": [
                {"name": "request_id", "type": "str"},
                {"name": "work_item", "type": "str"},
                {"name": "mode", "type": "str"}
              ],
              "return_type": "str"
            },
            {
              "name": "close_session",
              "parameters": [{"name": "session_id", "type": "str"}],
              "return_type": "bool"
            }
          ],
          "lifecycle": "In-process instance",
          "state_ownership": "Session state and variables"
        }
      ]
    },
    {
      "name": "logical_agent",
      "classes": [
        {
          "class_name": "BaseLogicalAgent",
          "responsibilities": ["Lớp cơ sở đại diện cho logical agent chạy in-memory"],
          "methods": [
            {
              "name": "run",
              "parameters": [
                {"name": "shared_context", "type": "dict"},
                {"name": "delta", "type": "dict"}
              ],
              "return_type": "dict"
            }
          ],
          "lifecycle": "Transient task worker",
          "state_ownership": "Delta context"
        }
      ]
    },
    {
      "name": "external_executor",
      "classes": [
        {
          "class_name": "ExternalExecutor",
          "responsibilities": ["Gateway duy nhất spawn OS subprocess Popen và dọn dẹp PGID tree"],
          "methods": [
            {
              "name": "execute_command",
              "parameters": [
                {"name": "cmd", "type": "list[str]"},
                {"name": "timeout", "type": "float"}
              ],
              "return_type": "tuple[int, str, str]"
            }
          ],
          "lifecycle": "Stateless wrapper class",
          "state_ownership": "None"
        }
      ]
    }
  ],
  "configuration": {
    "schema": {
      "experimental_session_runtime": "boolean",
      "runtime": {
        "max_concurrency": "integer",
        "write_behind_interval_seconds": "float"
      }
    },
    "defaults": {
      "experimental_session_runtime": true,
      "runtime": {
        "max_concurrency": 4,
        "write_behind_interval_seconds": 2.0
      }
    }
  },
  "database": {
    "tables": [
      {
        "table_name": "events",
        "columns": [
          {"name": "event_id", "type": "TEXT", "constraints": "PRIMARY KEY"},
          {"name": "session_id", "type": "TEXT", "constraints": "NOT NULL"},
          {"name": "timestamp", "type": "TEXT", "constraints": "NOT NULL"},
          {"name": "topic", "type": "TEXT", "constraints": "NOT NULL"},
          {"name": "payload", "type": "TEXT", "constraints": "NOT NULL"}
        ]
      }
    ],
    "growth_estimation": "10KB per session run",
    "maintenance_strategy": "Auto-vacuum and rotate sqlite database"
  },
  "cache": {
    "keys": ["SHARED_CONTEXT_CACHE"],
    "ttl_seconds": 0,
    "invalidation_rules": ["Evicted on session close or memory threshold exceed"]
  },
  "errors": [
    {
      "exception_class": "ForbiddenProcessSpawnError",
      "trigger": "Subprocess Validator detects spawn call outside Tool Executor",
      "recovery": "Graceful cancel session, kill all active tool processes"
    },
    {
      "exception_class": "StateConflictError",
      "trigger": "Optimistic Concurrency Control revision version mismatch on merge",
      "recovery": "Transition task to blocked_interactive state for manual merge"
    }
  ],
  "sequence_flows": [
    {
      "flow_name": "In-process Session Run Flow",
      "steps": [
        "Client CLI initializes SessionRuntimeCore in-process",
        "Read SQLite WAL journal to verify/resume state",
        "Scheduler builds DAG and enqueues task queues",
        "Worker executes Agent logic, reads from SHARED_CONTEXT_CACHE",
        "Agent calls run_tool API mapping to Tool Executor gateway",
        "Tool Executor spawns process with os.setsid() and streams output",
        "Agent finishes, merges delta into cache via OCC checks",
        "Session flushes cache to context.json and terminates cleanly"
      ]
    }
  ],
