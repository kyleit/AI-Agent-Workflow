{
  "modules": [
    {
      "name": "knowledge_runtime",
      "classes": [
        {
          "class_name": "KnowledgeRuntime",
          "responsibilities": [
            "Orchestrate semantic vector lookup, QMD filtering, and section resolver pipeline"
          ],
          "methods": [
            {
              "name": "search",
              "parameters": [
                "query: str",
                "limit: int"
              ],
              "return_type": "list[dict]"
            },
            {
              "name": "retrieve_context",
              "parameters": [
                "query: str"
              ],
              "return_type": "str"
            }
          ],
          "lifecycle": "Transient",
          "state_ownership": "Local workspace state"
        }
      ]
    },
    {
      "name": "obsidian_resolver",
      "classes": [
        {
          "class_name": "ObsidianSectionResolver",
          "responsibilities": [
            "Extract contents of a specific section matching headers without scan"
          ],
          "methods": [
            {
              "name": "extract_section",
              "parameters": [
                "file_path: str",
                "heading: str"
              ],
              "return_type": "str"
            }
          ],
          "lifecycle": "Transient",
          "state_ownership": "Read-only file access"
        }
      ]
    }
  ],
  "configuration": {
    "schema": {
      "qdrant": {
        "host": "str",
        "port": "int",
        "collection_name": "str"
      },
      "cache": {
        "enabled": "bool",
        "ttl_seconds": "int"
      }
    },
    "defaults": {
      "qdrant": {
        "host": "localhost",
        "port": 6333,
        "collection_name": "aiwf_knowledge"
      },
      "cache": {
        "enabled": true,
        "ttl_seconds": 600
      }
    }
  },
  "database": {
    "tables": [
      "qmd_metadata"
    ],
    "growth_estimation": "Less than 10MB for typical repositories up to 10,000 files.",
    "maintenance_strategy": "Auto-pruned on project memory rebuild commands."
  },
  "cache": {
    "keys": [
      "kr:query:<query_hash>:<limit>",
      "kr:doc:<doc_id_hash>"
    ],
    "ttl_seconds": 600,
    "invalidation_rules": [
      "Manual cache clear command execution",
      "Content hash change on document updates"
    ]
  },
  "errors": [
    {
      "exception_class": "KnowledgeProviderUnavailableError",
      "trigger": "Both Qdrant and SQLite databases are unreachable",
      "recovery": "Workspace fallback to local index parsing and static keyword lookup"
    }
  ],
  "sequence_flows": [
    {
      "flow_name": "Retrieve Context Sequence",
      "steps": [
        "Client requests context.",
        "Check cache. If hit, return immediately.",
        "On miss, query Qdrant vectors.",
        "Use Point IDs to query SQLite QMD metadata table.",
        "Resolve file paths and header tags.",
        "Extract content sections via Obsidian Section Resolver.",
        "Cache and return context block."
      ]
    }
  ],
  "integration_contracts": [
    "project-rag-search client integrations"
  ],
  "cli_contracts": [
    "aiwf knowledge search",
    "aiwf knowledge status",
    "aiwf knowledge cache clear"
  ],
  "implementation_contracts": [
    {
      "file_path": "skills/knowledge-runtime/scripts/knowledge_runtime.py",
      "owner": "Coder",
      "notes": "Orchestrates vector and relational lookup flow"
    },
    {
      "file_path": "skills/workflow-runtime/scripts/db.py",
      "owner": "Database Developer",
      "notes": "Introduces QMD mapping schemas"
    }
  ],
