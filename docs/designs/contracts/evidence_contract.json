{
  "$contract": "vir/evidence/v1",
  "title": "Evidence Contract Specification",
  "version": "1.0.0",
  "envelope": {
    "evidence_id": {
      "type": "string",
      "format": "uuid",
      "description": "Unique identifier of sensory evidence."
    },
    "source_agent": {
      "type": "string",
      "description": "Identifying name of audit module/agent."
    },
    "classification": {
      "type": "string",
      "description": "Violation classification tag."
    },
    "payload": {
      "type": "object",
      "description": "Structured details coordinates of findings."
    },
    "timestamp": {
      "type": "number",
      "description": "Epoch timestamp of finding."
    }
  },
  "required": [
    "evidence_id",
    "source_agent",
    "classification",
    "payload",
    "timestamp"
  ]
}
