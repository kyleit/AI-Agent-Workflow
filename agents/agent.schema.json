{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "AIWF_Agent_Schema",
  "type": "OBJECT",
  "properties": {
    "id": { "type": "STRING" },
    "name": { "type": "STRING" },
    "display_name": { "type": "STRING" },
    "version": { "type": "STRING" },
    "agent_category": { 
      "type": "STRING", 
      "enum": ["discovery", "planning", "architecture", "implementation", "review", "release"] 
    },
    "role": { "type": "STRING" },
    "description": { "type": "STRING" },
    "capabilities": {
      "type": "ARRAY",
      "items": { "type": "STRING" }
    },
    "specializations": {
      "type": "ARRAY",
      "items": { "type": "STRING" }
    },
    "phase_ownership": {
      "type": "ARRAY",
      "items": { 
        "type": "STRING", 
        "enum": ["brainstorm", "planning", "blueprint", "implementation", "validation", "review", "release"] 
      }
    },
    "spawn_conditions": {
      "type": "OBJECT",
      "properties": {
        "phases": { "type": "ARRAY", "items": { "type": "STRING" } },
        "task_tags": { "type": "ARRAY", "items": { "type": "STRING" } },
        "file_patterns": { "type": "ARRAY", "items": { "type": "STRING" } },
        "capabilities_required": { "type": "ARRAY", "items": { "type": "STRING" } },
        "confidence_minimum": { "type": "NUMBER" }
      },
      "additionalProperties": false
    },
    "input_contract": { "type": "STRING" },
    "output_contract": { "type": "STRING" },
    "permissions": {
      "type": "OBJECT",
      "properties": {
        "mode": { 
          "type": "STRING", 
          "enum": ["read-only", "scoped-write", "isolated-write", "authoritative-write"] 
        }
      },
      "required": ["mode"],
      "additionalProperties": false
    },
    "write_mode": {
      "type": "STRING",
      "enum": ["none", "single-writer", "isolated-writer", "integration-owner"]
    },
    "ownership_scope": {
      "type": "OBJECT",
      "properties": {
        "include": { "type": "ARRAY", "items": { "type": "STRING" } },
        "exclude": { "type": "ARRAY", "items": { "type": "STRING" } }
      },
      "required": ["include"],
      "additionalProperties": false
    },
    "allowed_reads": {
      "type": "ARRAY",
      "items": { "type": "STRING" }
    },
    "allowed_writes": {
      "type": "ARRAY",
      "items": { "type": "STRING" }
    },
    "forbidden_actions": {
      "type": "ARRAY",
      "items": { "type": "STRING" }
    },
    "required_skills": {
      "type": "ARRAY",
      "items": { "type": "STRING" }
    },
    "required_tools": {
      "type": "ARRAY",
      "items": { "type": "STRING" }
    },
    "tool_allowlist": {
      "type": "ARRAY",
      "items": { "type": "STRING" }
    },
    "model_preferences": {
      "type": "ARRAY",
      "items": { "type": "STRING" }
    },
    "priority": { "type": "INTEGER" },
    "max_concurrency": { "type": "INTEGER" },
    "resource_limits": { "type": "OBJECT" },
    "confidence_threshold": {
      "type": "OBJECT",
      "properties": {
        "brainstorm": { "type": "INTEGER" },
        "planning": { "type": "INTEGER" },
        "blueprint": { "type": "INTEGER" }
      },
      "additionalProperties": false
    },
    "handoff_targets": {
      "type": "ARRAY",
      "items": { "type": "STRING" }
    },
    "done_criteria": { "type": "STRING" },
    "failure_behavior": { "type": "STRING" },
    "retry_policy": { "type": "OBJECT" },
    "observability": { "type": "STRING" },
    "runtime_visibility": { "type": "BOOLEAN" },
    "can_run_in_parallel": { "type": "BOOLEAN" },
    "isolation_required": { "type": "BOOLEAN" }
  },
  "required": [
    "id", "name", "role", "description", "capabilities", "permissions", "write_mode",
    "allowed_reads", "allowed_writes", "forbidden_actions", "handoff_targets"
  ],
  "additionalProperties": false
}
